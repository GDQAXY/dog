/* 二手闲置页面样式 */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

.header {
  background: var(--white);
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
}

.publish-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--white);
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.filter-tabs {
  display: flex;
  gap: 32rpx;
  overflow-x: auto;
}

.filter-tab {
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 12rpx 0;
  font-weight: 500;
  position: relative;
  white-space: nowrap;
}

.filter-tab.active {
  color: var(--primary);
  font-weight: 600;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
  border-radius: 4rpx;
}

.item-list {
  padding: 24rpx 30rpx;
}

.item-card {
  display: flex;
  gap: 24rpx;
  background: var(--white);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.item-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  flex: 1;
  margin-right: 16rpx;
}

.item-price {
  font-size: 30rpx;
  font-weight: 700;
}

.item-location {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
