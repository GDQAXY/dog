/* 运输页面样式 */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

.header {
  background: var(--white);
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
}

.map-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f5f5f5;
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text);
}

.filter-tabs {
  display: flex;
  gap: 32rpx;
  overflow-x: auto;
}

.filter-tab {
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 12rpx 0;
  font-weight: 500;
  position: relative;
  white-space: nowrap;
}

.filter-tab.active {
  color: var(--primary);
  font-weight: 600;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
  border-radius: 4rpx;
}

.route-list {
  padding: 24rpx 30rpx;
}

.route-card {
  display: flex;
  gap: 24rpx;
  background: var(--white);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.route-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  flex-shrink: 0;
}

.route-info {
  flex: 1;
  min-width: 0;
}

.route-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.route-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.route-rating {
  font-size: 26rpx;
  color: #ffa500;
  font-weight: 600;
}

.route-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.route-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.route-price {
  text-align: right;
  flex-shrink: 0;
}

.route-price .price {
  font-size: 40rpx;
  display: block;
}

.route-price .price-unit {
  font-size: 22rpx;
  color: var(--text-light);
}

.service-section {
  padding: 0 30rpx;
  margin-top: 24rpx;
}

.service-section .section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 24rpx;
  display: block;
}

.service-list {
  display: flex;
  justify-content: space-around;
  background: var(--white);
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: var(--shadow);
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.service-icon {
  font-size: 48rpx;
}

.service-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}
