<!-- 运输页面 -->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-top">
      <text class="header-title">宠物运输</text>
      <view class="map-btn" bindtap="planRoute">
        <text>🗺️</text>
        <text>路线规划</text>
      </view>
    </view>
    <view class="filter-tabs">
      <view class="filter-tab {{currentFilter === 0 ? 'active' : ''}}" bindtap="switchFilter" data-index="0">专车托运</view>
      <view class="filter-tab {{currentFilter === 1 ? 'active' : ''}}" bindtap="switchFilter" data-index="1">航空运输</view>
      <view class="filter-tab {{currentFilter === 2 ? 'active' : ''}}" bindtap="switchFilter" data-index="2">火车托运</view>
      <view class="filter-tab {{currentFilter === 3 ? 'active' : ''}}" bindtap="switchFilter" data-index="3">顺风车</view>
    </view>
  </view>

  <!-- 路线列表 -->
  <view class="route-list">
    <view class="route-card" wx:for="{{routes}}" wx:key="id" bindtap="onRouteTap" data-item="{{item}}">
      <view class="route-icon" style="background: {{item.bg}}">{{item.icon}}</view>
      <view class="route-info">
        <view class="route-name-row">
          <text class="route-name">{{item.name}}</text>
          <text class="route-rating">⭐ {{item.rating}}</text>
        </view>
        <text class="route-desc">{{item.desc}}</text>
        <view class="route-tags">
          <text class="tag" wx:for="{{item.tags}}" wx:key="index">{{item}}</text>
        </view>
      </view>
      <view class="route-price">
        <text class="price">¥{{item.price}}</text>
        <text class="price-unit">/起</text>
      </view>
    </view>
  </view>

  <!-- 服务保障 -->
  <view class="service-section">
    <text class="section-title">服务保障</text>
    <view class="service-list">
      <view class="service-item">
        <text class="service-icon">🛡️</text>
        <text class="service-text">全程保险</text>
      </view>
      <view class="service-item">
        <text class="service-icon">📍</text>
        <text class="service-text">实时定位</text>
      </view>
      <view class="service-item">
        <text class="service-icon">🎥</text>
        <text class="service-text">视频追踪</text>
      </view>
      <view class="service-item">
        <text class="service-icon">🏥</text>
        <text class="service-text">医疗保障</text>
      </view>
    </view>
  </view>
</view>
