/* 我的页面样式 */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

/* 用户信息头部 */
.profile-header {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 80rpx 40rpx 60rpx;
  color: var(--white);
  border-radius: 0 0 64rpx 64rpx;
  position: relative;
  overflow: hidden;
}

.profile-header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 600rpx;
  height: 600rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 32rpx;
  position: relative;
}

.avatar-wrap {
  position: relative;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 96rpx;
  border: 6rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.vip-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: var(--white);
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  border: 4rpx solid var(--white);
}

.profile-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.profile-name {
  font-size: 44rpx;
  font-weight: 700;
}

.level-tag {
  background: rgba(255,255,255,0.2);
  padding: 4rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.profile-meta {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 8rpx;
}

.profile-id {
  font-size: 22rpx;
  opacity: 0.7;
}

.setting-btn {
  position: absolute;
  right: 0;
  top: 0;
  font-size: 44rpx;
  opacity: 0.9;
  padding: 16rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}

/* 统计 */
.profile-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 48rpx;
  text-align: center;
  position: relative;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 卡片通用 */
.card {
  background: var(--white);
  border-radius: 40rpx;
  margin: 24rpx 30rpx;
  box-shadow: var(--shadow);
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.section-more {
  font-size: 26rpx;
  color: var(--primary);
}

/* 宠物列表 */
.pets-section {
  margin-top: -30rpx;
}

.pet-scroll {
  white-space: nowrap;
}

.pet-list {
  display: inline-flex;
  gap: 24rpx;
}

.pet-card {
  width: 280rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-radius: 40rpx;
  padding: 40rpx;
  text-align: center;
  color: var(--white);
}

.pet-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin: 0 auto 20rpx;
}

.pet-name {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.pet-breed {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 16rpx;
}

.pet-health {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.add-pet-card {
  width: 200rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-light);
  border: 4rpx dashed #ddd;
}

.add-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.add-text {
  font-size: 24rpx;
}

/* 钱包 */
.wallet-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.wallet-item {
  text-align: center;
  padding: 20rpx 0;
}

.wallet-item.highlight .wallet-value {
  color: var(--danger);
}

.wallet-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
  display: block;
}

.wallet-label {
  font-size: 22rpx;
  color: var(--text-light);
}

/* 消息和订单 */
.notice-grid,
.order-grid {
  display: flex;
  justify-content: space-around;
}

.notice-item,
.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  position: relative;
}

.notice-icon-wrap,
.order-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #f8f9fa, #fff);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  position: relative;
}

.notice-icon,
.order-icon {
  font-size: 48rpx;
}

.notice-badge,
.order-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, var(--danger), #ff6b81);
  color: var(--white);
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}

.notice-name,
.order-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 我的服务 */
.service-section .section-title {
  margin-bottom: 24rpx;
}

.service-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.service-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #f8f9fa, #fff);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.service-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 菜单列表 */
.menu-list {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: var(--text);
  font-weight: 500;
}

.menu-tag {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--white);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  margin-right: 16rpx;
}

.menu-arrow {
  color: #ccc;
  font-size: 36rpx;
}

/* 退出登录 */
.logout-btn {
  margin: 40rpx 30rpx;
  padding: 32rpx;
  background: var(--white);
  color: var(--danger);
  text-align: center;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: var(--shadow);
}
