<!-- 我的页面 -->
<view class="container">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <view class="profile-top">
      <view class="avatar-wrap">
        <view class="profile-avatar">{{userInfo.avatar}}</view>
        <view class="vip-badge">VIP</view>
      </view>
      <view class="profile-info">
        <view class="name-row">
          <text class="profile-name">{{userInfo.name}}</text>
          <text class="level-tag">{{userInfo.level}}</text>
        </view>
        <text class="profile-meta">📍 {{userInfo.location}} | {{userInfo.pets}}</text>
        <text class="profile-id">ID: {{userInfo.id}}</text>
      </view>
      <view class="setting-btn" bindtap="goToSetting">⚙️</view>
    </view>
    <view class="profile-stats">
      <view class="stat-item" bindtap="viewStats" data-type="collect">
        <text class="stat-num">{{userInfo.stats.collect}}</text>
        <text class="stat-label">收藏</text>
      </view>
      <view class="stat-item" bindtap="viewStats" data-type="follow">
        <text class="stat-num">{{userInfo.stats.follow}}</text>
        <text class="stat-label">关注</text>
      </view>
      <view class="stat-item" bindtap="viewStats" data-type="fans">
        <text class="stat-num">{{userInfo.stats.fans}}</text>
        <text class="stat-label">粉丝</text>
      </view>
      <view class="stat-item" bindtap="viewStats" data-type="likes">
        <text class="stat-num">{{userInfo.stats.likes}}</text>
        <text class="stat-label">获赞</text>
      </view>
    </view>
  </view>

  <!-- 我的宠物 -->
  <view class="pets-section card">
    <view class="section-header">
      <text class="section-title">🐾 我的宠物</text>
      <text class="section-more" bindtap="managePets">管理 ></text>
    </view>
    <scroll-view class="pet-scroll" scroll-x="true">
      <view class="pet-list">
        <view class="pet-card" wx:for="{{pets}}" wx:key="id" bindtap="viewPet" data-item="{{item}}">
          <view class="pet-avatar">{{item.avatar}}</view>
          <text class="pet-name">{{item.name}}</text>
          <text class="pet-breed">{{item.type}} · {{item.age}}</text>
          <text class="pet-health">{{item.health}}</text>
        </view>
        <view class="add-pet-card" bindtap="addPet">
          <text class="add-icon">+</text>
          <text class="add-text">添加宠物</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 我的钱包 -->
  <view class="wallet-section card" bindtap="goToWallet">
    <view class="section-header">
      <text class="section-title">💰 我的钱包</text>
      <text class="section-more">查看明细 ></text>
    </view>
    <view class="wallet-grid">
      <view class="wallet-item">
        <text class="wallet-value">¥{{wallet.balance}}</text>
        <text class="wallet-label">余额</text>
      </view>
      <view class="wallet-item">
        <text class="wallet-value">{{wallet.coupon}}</text>
        <text class="wallet-label">优惠券</text>
      </view>
      <view class="wallet-item">
        <text class="wallet-value">{{wallet.points}}</text>
        <text class="wallet-label">积分</text>
      </view>
      <view class="wallet-item highlight">
        <text class="wallet-value">¥{{wallet.cashback}}</text>
        <text class="wallet-label">待返现</text>
      </view>
    </view>
  </view>

  <!-- 消息中心 -->
  <view class="notice-section card" bindtap="goToMessage">
    <view class="section-header">
      <text class="section-title">🔔 消息中心</text>
      <text class="section-more">查看全部 ></text>
    </view>
    <view class="notice-grid">
      <view class="notice-item" wx:for="{{messages}}" wx:key="id" catchtap="viewMessage" data-item="{{item}}">
        <view class="notice-icon-wrap">
          <text class="notice-icon">{{item.icon}}</text>
          <view class="notice-badge" wx:if="{{item.count > 0}}">{{item.count}}</view>
        </view>
        <text class="notice-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 我的订单 -->
  <view class="order-section card">
    <view class="section-header">
      <text class="section-title">📋 我的订单</text>
      <text class="section-more" bindtap="viewAllOrders">全部 ></text>
    </view>
    <view class="order-grid">
      <view class="order-item" wx:for="{{orders}}" wx:key="id" bindtap="viewOrder" data-item="{{item}}">
        <view class="order-icon-wrap">
          <text class="order-icon">{{item.icon}}</text>
          <view class="order-badge" wx:if="{{item.count > 0}}">{{item.count}}</view>
        </view>
        <text class="order-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 我的服务 -->
  <view class="service-section card">
    <text class="section-title">🎯 我的服务</text>
    <view class="service-grid">
      <view class="service-item" wx:for="{{services}}" wx:key="id" bindtap="onServiceTap" data-item="{{item}}">
        <view class="service-icon-wrap">
          <text class="service-icon">{{item.icon}}</text>
        </view>
        <text class="service-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 更多功能 -->
  <view class="menu-list card">
    <view class="menu-item" wx:for="{{menuList}}" wx:key="id" bindtap="onMenuTap" data-item="{{item}}">
      <view class="menu-icon" style="background: {{item.bg}}; color: {{item.color}}">{{item.icon}}</view>
      <text class="menu-text">{{item.name}}</text>
      <view class="menu-tag" wx:if="{{item.tag}}">{{item.tag}}</view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="logout">退出登录</view>

  <view style="height: 40rpx;"></view>
</view>
