/* 领券页面样式 */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

.header {
  background: var(--white);
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
}

/* 新人专享卡片 */
.new-user-card {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--white);
  padding: 48rpx;
  border-radius: 48rpx;
  margin: 24rpx 30rpx;
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.3);
  position: relative;
  overflow: hidden;
}

.new-user-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}

.new-user-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  position: relative;
}

.new-user-desc {
  display: block;
  font-size: 28rpx;
  opacity: 0.95;
  margin-bottom: 32rpx;
  position: relative;
}

.new-user-btn {
  background: var(--white);
  color: var(--primary);
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

/* 区块 */
.section {
  padding: 0 30rpx;
  margin-top: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 24rpx;
  display: block;
}

/* 优惠券列表 */
.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.coupon-card {
  display: flex;
  background: var(--white);
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: var(--shadow);
}

.coupon-left {
  width: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.coupon-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--white);
}

.coupon-info {
  flex: 1;
  padding: 30rpx;
  min-width: 0;
}

.coupon-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.coupon-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.coupon-tag {
  background: var(--danger);
  color: var(--white);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.coupon-valid {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.coupon-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.claim-btn {
  align-self: center;
  margin-right: 30rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--white);
  border: none;
}
