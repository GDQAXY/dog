/* 社区页面样式 */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  background: var(--white);
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid #f0f0f0;
}

.community-tabs {
  white-space: nowrap;
}

.tab-list {
  display: inline-flex;
  padding: 0 30rpx;
  gap: 40rpx;
}

.community-tab {
  font-size: 30rpx;
  color: var(--text-secondary);
  padding: 16rpx 0;
  font-weight: 500;
  position: relative;
  white-space: nowrap;
}

.community-tab.active {
  color: var(--primary);
  font-weight: 600;
}

.community-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
  border-radius: 4rpx;
}

/* 帖子列表 */
.post-list {
  padding: 24rpx 30rpx;
}

.post-card {
  background: var(--white);
  border-radius: 40rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.post-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.post-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.post-user {
  flex: 1;
}

.post-username {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
}

.post-time {
  font-size: 24rpx;
  color: var(--text-light);
  display: block;
  margin-top: 4rpx;
}

.post-follow {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--white);
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.post-content {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  margin-bottom: 24rpx;
  display: block;
}

.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.post-image {
  aspect-ratio: 1;
  background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.post-actions {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.post-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.action-icon {
  font-size: 32rpx;
}

/* 发布按钮 */
.publish-btn {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.4);
  font-size: 48rpx;
}
