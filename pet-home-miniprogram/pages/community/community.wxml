<!-- 社区页面 -->
<view class="container">
  <!-- 社区标签 -->
  <view class="header">
    <scroll-view class="community-tabs" scroll-x="true">
      <view class="tab-list">
        <view class="community-tab {{currentTab === index ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="index" bindtap="switchTab" data-index="{{index}}">
          {{item}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 帖子列表 -->
  <view class="post-list">
    <view class="post-card" wx:for="{{posts}}" wx:key="id">
      <view class="post-header">
        <view class="post-avatar" style="background: {{item.avatarBg}}">{{item.avatar}}</view>
        <view class="post-user">
          <text class="post-username">{{item.username}}</text>
          <text class="post-time">{{item.time}} · {{item.location}}</text>
        </view>
        <view class="post-follow" bindtap="followUser" data-item="{{item}}">
          <text>+ 关注</text>
        </view>
      </view>
      <text class="post-content">{{item.content}}</text>
      <view class="post-images" wx:if="{{item.images.length > 0}}">
        <view class="post-image" wx:for="{{item.images}}" wx:for-item="img" wx:key="index">🖼️</view>
      </view>
      <view class="post-actions">
        <view class="post-action" bindtap="likePost" data-item="{{item}}">
          <text class="action-icon">❤️</text>
          <text>{{item.likes}}</text>
        </view>
        <view class="post-action" bindtap="commentPost" data-item="{{item}}">
          <text class="action-icon">💬</text>
          <text>{{item.comments}}</text>
        </view>
        <view class="post-action" bindtap="collectPost" data-item="{{item}}">
          <text class="action-icon">⭐</text>
          <text>收藏</text>
        </view>
        <view class="post-action" bindtap="sharePost" data-item="{{item}}">
          <text class="action-icon">↗️</text>
          <text>分享</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="publish-btn" bindtap="showPublish">
    <text>✏️</text>
  </view>
</view>
