/* 医疗页面样式 */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  background: var(--white);
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
}

.emergency-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #ff6b6b, #ee5a6f);
  color: var(--white);
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

/* 快捷菜单 */
.quick-menu {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  padding: 30rpx;
  margin: 24rpx 30rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.menu-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

.menu-icon.green { background: linear-gradient(135deg, #e8f5e9, #c8e6c9); }
.menu-icon.blue { background: linear-gradient(135deg, #e3f2fd, #bbdefb); }
.menu-icon.orange { background: linear-gradient(135deg, #fff3e0, #ffe0b2); }
.menu-icon.purple { background: linear-gradient(135deg, #f3e5f5, #e1bee7); }

.menu-text {
  font-size: 24rpx;
  color: var(--text);
}

/* AI卡片 */
.ai-card {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--white);
  padding: 56rpx;
  border-radius: 48rpx;
  margin: 0 30rpx 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.3);
  position: relative;
  overflow: hidden;
}

.ai-card::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}

.ai-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  position: relative;
}

.ai-desc {
  display: block;
  font-size: 28rpx;
  opacity: 0.95;
  margin-bottom: 48rpx;
  line-height: 1.6;
  position: relative;
}

.ai-btn {
  background: var(--white);
  color: var(--primary);
  padding: 28rpx 64rpx;
  border-radius: 56rpx;
  border: none;
  font-weight: 700;
  font-size: 30rpx;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

/* 区块 */
.section {
  padding: 0 30rpx;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 24rpx;
  display: block;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-more {
  font-size: 26rpx;
  color: var(--primary);
}

/* 症状标签 */
.symptom-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.symptom-tag {
  background: #f5f5f5;
  padding: 20rpx 36rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: var(--text);
}

/* 医生卡片 */
.doctor-card {
  display: flex;
  gap: 24rpx;
  background: var(--white);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.doctor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  flex-shrink: 0;
}

.doctor-info {
  flex: 1;
  min-width: 0;
}

.doctor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
  display: block;
}

.doctor-meta {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  display: block;
}

.doctor-price {
  font-size: 28rpx;
  color: var(--danger);
  font-weight: 700;
}

.consult-btn {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--white);
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  align-self: center;
  border: none;
}

/* 医院卡片 */
.hospital-card {
  display: flex;
  gap: 24rpx;
  background: var(--white);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.hospital-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.hospital-info {
  flex: 1;
  min-width: 0;
}

.hospital-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.hospital-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.hospital-rating {
  font-size: 26rpx;
  color: #ffa500;
}

.hospital-location {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.hospital-tags {
  display: flex;
  gap: 12rpx;
}
