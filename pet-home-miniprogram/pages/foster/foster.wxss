/* 寄养页面样式 */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 120rpx;
}

/* 头部 */
.header {
  background: var(--white);
  padding: 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
}

.map-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f5f5f5;
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text);
}

/* 筛选Tab */
.filter-tabs {
  display: flex;
  gap: 48rpx;
}

.filter-tab {
  font-size: 30rpx;
  color: var(--text-secondary);
  padding: 12rpx 0;
  font-weight: 500;
  position: relative;
}

.filter-tab.active {
  color: var(--primary);
  font-weight: 600;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
  border-radius: 4rpx;
}

/* 地图预览 */
.map-preview {
  height: 400rpx;
  background: linear-gradient(135deg, #c3cfe2, #f5f7fa);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.map-placeholder {
  text-align: center;
  color: var(--text-secondary);
}

.map-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.map-text {
  display: block;
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.map-subtext {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
}

.map-marker {
  position: absolute;
  font-size: 60rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

/* 寄养家庭列表 */
.host-list {
  padding: 24rpx 30rpx;
}

.host-card {
  display: flex;
  gap: 24rpx;
  background: var(--white);
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.host-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  flex-shrink: 0;
}

.host-info {
  flex: 1;
  min-width: 0;
}

.host-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.host-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.host-rating {
  font-size: 26rpx;
  color: #ffa500;
  font-weight: 600;
}

.host-location {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.host-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.host-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.host-price {
  text-align: right;
  flex-shrink: 0;
}

.host-price .price {
  font-size: 40rpx;
  display: block;
}

.host-price .price-unit {
  display: block;
  font-size: 22rpx;
}

/* 底部按钮 */
.bottom-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: var(--white);
  padding: 28rpx 60rpx;
  border-radius: 60rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.4);
}

.btn-icon {
  font-size: 40rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 700;
}
