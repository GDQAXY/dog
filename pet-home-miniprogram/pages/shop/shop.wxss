/* 商城页面样式 */
.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

.header {
  background: var(--white);
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
}

.cart-btn {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 40rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: var(--danger);
  color: var(--white);
  font-size: 20rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.filter-tabs {
  display: flex;
  gap: 32rpx;
  overflow-x: auto;
}

.filter-tab {
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 12rpx 0;
  font-weight: 500;
  position: relative;
  white-space: nowrap;
}

.filter-tab.active {
  color: var(--primary);
  font-weight: 600;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
  border-radius: 4rpx;
}

.product-list {
  padding: 24rpx 30rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.product-card {
  width: calc(50% - 12rpx);
  background: var(--white);
  border-radius: 32rpx;
  padding: 20rpx;
  box-shadow: var(--shadow);
}

.product-img {
  height: 280rpx;
  background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 16rpx;
}

.product-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: linear-gradient(135deg, var(--danger), #ff6b81);
  color: var(--white);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.product-icon {
  font-size: 100rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 8rpx;
  display: block;
  line-height: 1.4;
}

.product-desc {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 12rpx;
  display: block;
}

.product-price {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.current-price {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--danger);
}

.original-price {
  font-size: 24rpx;
  color: var(--text-light);
  text-decoration: line-through;
}

.product-sold {
  font-size: 22rpx;
  color: var(--text-light);
}
