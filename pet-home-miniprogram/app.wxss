/**app.wxss**/
page {
  --primary: #667eea;
  --primary-dark: #764ba2;
  --secondary: #f5576c;
  --success: #11998e;
  --warning: #ff9800;
  --danger: #ff4757;
  --info: #4facfe;
  --bg: #f5f7fa;
  --text: #333;
  --text-secondary: #666;
  --text-light: #999;
  --border: #f0f0f0;
  --white: #fff;
  --shadow: 0 2px 12px rgba(0,0,0,0.04);
}

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background: var(--bg);
  color: var(--text);
  font-size: 14px;
  line-height: 1.5;
}

/* 通用样式 */
.container {
  padding: 0 16px;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* 卡片样式 */
.card {
  background: var(--white);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.card-header {
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border);
}

.card-body {
  padding: 30rpx;
}

/* 渐变背景 */
.gradient-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
}

.gradient-pink {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.gradient-blue {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.gradient-green {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

/* 按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: var(--white);
}

.btn-danger {
  background: linear-gradient(135deg, var(--danger) 0%, #ff6b81 100%);
  color: var(--white);
}

.btn-white {
  background: var(--white);
  color: var(--primary);
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: #f0f2f5;
  color: var(--text-secondary);
  font-size: 22rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
}

.tag-primary {
  background: rgba(102, 126, 234, 0.1);
  color: var(--primary);
}

.tag-danger {
  background: rgba(255, 71, 87, 0.1);
  color: var(--danger);
}

/* 价格样式 */
.price {
  color: var(--danger);
  font-weight: 700;
}

.price-unit {
  font-size: 22rpx;
  color: var(--text-light);
}

.original-price {
  font-size: 22rpx;
  color: var(--text-light);
  text-decoration: line-through;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* 宫格样式 */
.grid {
  display: grid;
  gap: 20rpx;
}

.grid-4 {
  grid-template-columns: repeat(4, 1fr);
}

.grid-5 {
  grid-template-columns: repeat(5, 1fr);
}

/* 图标容器 */
.icon-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

/* 头像 */
.avatar {
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--white);
}

.avatar-sm {
  width: 60rpx;
  height: 60rpx;
  font-size: 32rpx;
}

.avatar-md {
  width: 80rpx;
  height: 80rpx;
  font-size: 40rpx;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
  font-size: 60rpx;
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}

/* 加载动画 */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* 脉冲动画 */
@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.pulse {
  animation: pulse 2s infinite;
}

/* 淡入动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.3s ease;
}

/* 文字省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
